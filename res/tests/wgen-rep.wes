void <- main()
{
    print("--- СТРЕСС-ТЕСТ: ВЕТВЛЕНИЯ И ЦИКЛЫ ---")
    print()

    print("1. Короткое замыкание (Short-circuiting)")
    val int zero = 0
    var int safe_check = 0

    # ЛОВУШКА 1: Если 'or' вычислит правую часть, ВМ умрет от деления на ноль!
    when (zero == 0 or (100 / zero) > 0) {
        safe_check = 1
    }
    print("safe_check OR (1):", safe_check)

    # ЛОВУШКА 2: Если 'and' пойдет дальше первого false, тоже будет паника!
    when (zero >< 0 and (100 / zero) > 0) {
        safe_check = 999
    } else {
        safe_check = 2
    }
    print("safe_check AND (2):", safe_check)
    print()

    print("2. Глубокая вложенность (Jump Table Patching)")
    val int v = 42
    var int path = 0

    # ЛОВУШКА 3: Проверка адресов прыжков. Если патчинг смещений съехал,
    # мы попадем не в тот блок 'else' или перепрыгнем нужное присваивание.
    when (v < 10) {
        path = 1
    } else {
        when (v < 20) {
            path = 2
        } else {
            when (v < 50) {
                when (v == 42) {
                    path = 42
                } else {
                    path = 3
                }
            } else {
                path = 4
            }
        }
    }
    print("Nested path (42):", path)
    print()

    print("3. Цикл run (while) и мутации")
    var int n = 5
    var int fact = 1
    run (n > 0) {
        fact = fact * n
        n = n - 1
    }
    print("5! (120):", fact)
    print()

    print("4. Цикл do-while (постусловие)")
    var int dw_count = 0
    # ЛОВУШКА 4: Постусловие обязано выполнить блок хотя бы один раз
    {
        dw_count = dw_count + 10
    } run (false)
    print("Run once (10):", dw_count)

    var int steps = 0
    {
        steps = steps + 1
    } run (steps < 3)
    print("Run three times (3):", steps)
    print()

    print("5. Итератор rep (for) и вложенные циклы")
    var int matrix_sum = 0
    var int iterations = 0

    # Имитируем обход 2D-матрицы 3х3
    rep r in 0 .. 3 {
        rep c in 0 .. 3 {
            matrix_sum = matrix_sum + (r * c)
            iterations = iterations + 1
        }
    }
    # 0*0 + 0*1 ... + 2*2 = 9
    print("Matrix 3x3 sum (9):", matrix_sum)
    print("Total iterations (9):", iterations)
    print()

    print("6. Комбинированный тест (rep + when + run)")
    var int complex_res = 0
    rep i in 1 .. 10 {
        when (i % 2 == 0) {
            var int temp = i
            run (temp > 0) {
                complex_res = complex_res + 1
                temp = temp - 2
            }
        }
    }
    # Сумма итераций для четных чисел: 2(1) + 4(2) + 6(3) + 8(4) = 10
    print("Complex flow result (10):", complex_res)
    print()
    print("Все тесты Control Flow успешно пройдены!")
}
void <- testBreakRun()
{
    var int i = 0
    run (i < 10)
    {
        when
        {
            i == 5 -> break
        }
        i = i + 1
    }
    println(i)
    # ожидается: 5
}

void <- testContinueRun()
{
    var int i = 0
    var int sum = 0
    run (i < 10)
    {
        i = i + 1
        when
        {
            i % 2 == 0 -> continue
        }
        sum = sum + i
    }
    println(sum)
    # ожидается: 25 (нечётные: 1+3+5+7+9)
}

void <- testBreakClassicFor()
{
    var int stopped = 0
    repeat (int i = 0; i < 100; i = i + 1)
    {
        when
        {
            i == 7 -> break
        }
        stopped = i
    }
    println(stopped)
    # ожидается: 6
}

void <- testContinueRepeat()
{
    var int sum = 0
    repeat (i in 0 .. 10)
    {
        when
        {
            i % 3 == 0 -> continue
        }
        sum = sum + i
    }
    println(sum)
    # ожидается: 1+2+4+5+7+8 = 27
}

void <- testNestedBreak()
{
    var int outer = 0
    repeat (int i = 0; i < 3; i = i + 1)
    {
        repeat (int j = 0; j < 5; j = j + 1)
        {
            when
            {
                j == 2 -> break
            }
            outer = outer + 1
        }
    }
    println(outer)
    # ожидается: 6 (3 итерации внешнего * 2 итерации внутреннего)
}

void <- testBreakDoWhile()
{
    var int i = 0
    {
        when
        {
            i == 3 -> break
        }

        i = i + 1
    } run (i < 10)
    println(i)
    # ожидается: 3
}

void <- testBreakWithLocals()
{
    var int result = 0
    repeat (int i = 0; i < 10; i = i + 1)
    {
        var int temp = i * 2
        when
        {
            temp > 8 -> break
        }
        result = temp
    }
    println(result)
    # ожидается: 8 (i=4, temp=8; при i=5 temp=10 > 8 → break)
}

void <- main()
{
    testBreakRun()
    testContinueRun()
    testBreakClassicFor()
    testContinueRepeat()
    testNestedBreak()
    testBreakDoWhile()
    testBreakWithLocals()
}

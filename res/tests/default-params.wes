int <- inc(int x, int by = 1)
{
    return x + by
}

int <- box(int w = 10, int h = 20)
{
    return w * h
}

string <- greet(string name, string greeting = "Привет")
{
    return greeting
}

int <- offset(int base, int delta = 3 + 4)
{
    return base + delta
}

real <- scale(real x, real factor = 2.0)
{
    return x * factor
}

void <- main()
{
    println(inc(5))
    println(inc(5, 3))

    println(box())
    println(box(5))
    println(box(5, 5))

    println(greet("Боб"))
    println(greet("Боб", "Хай"))

    println(offset(10))
    println(offset(10, 100))

    println(scale(4.0))
    println(scale(4.0, 0.5))
}


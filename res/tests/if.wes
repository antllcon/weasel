void <- testIfOnly()
{
    var int x = 5

    if (x > 0)
    {
        println(1)
    }

    if (x < 0)
    {
        println(0)
    }

    println(2)
}

void <- testIfElse()
{
    var int a = 10

    if (a > 5)
    {
        println(1)
    }
    else
    {
        println(0)
    }

    var int b = 2

    if (b > 5)
    {
        println(0)
    }
    else
    {
        println(1)
    }
}

void <- testChain()
{
    var int x = 0
    if (x > 0)
    {
        println(1)
    }
    else if (x < 0)
    {
        println(2)
    }
    else
    {
        println(3)
    }

    x = 5
    if (x > 0)
    {
        println(4)
    }
    else if (x < 0)
    {
        println(5)
    }
    else
    {
        println(6)
    }

    x = -3
    if (x > 0)
    {
        println(7)
    }
    else if (x < 0)
    {
        println(8)
    }
    else
    {
        println(9)
    }
}

void <- testLongChain(int grade)
{
    if (grade >= 90)
    {
        println(5)
    }
    else if (grade >= 75)
    {
        println(4)
    }
    else if (grade >= 60)
    {
        println(3)
    }
    else if (grade >= 45)
    {
        println(2)
    }
    else
    {
        println(1)
    }
}

void <- testLongChainCases()
{
    testLongChain(95)
    testLongChain(80)
    testLongChain(60)
    testLongChain(50)
    testLongChain(10)
}

void <- testNested()
{
    var int x = 3
    var int y = 7

    if (x > 0)
    {
        if (y > 5)
        {
            println(1)
        }
        else
        {
            println(2)
        }
    }
    else
    {
        println(3)
    }

    x = -1

    if (x > 0)
    {
        if (y > 5)
        {
            println(4)
        }
    }
    else
    {
        println(5)
    }
}

void <- testLogicalOps()
{
    var int a = 3
    var int b = 7

    if (a > 0 and b > 0)
    {
        println(1)
    }

    if (a > 10 or b > 5)
    {
        println(2)
    }

    if (not (a > 10))
    {
        println(3)
    }

    if (a > 0 and b > 10)
    {
        println(0)
    }
    else
    {
        println(4)
    }

    if (a > 10 or b > 5)
    {
        println(5)
    }

    if (not (a > 0))
    {
        println(0)
    }
    else
    {
        println(6)
    }
}

void <- testEquality()
{
    var int x = 42
    if (x == 42)
    {
        println(1)
    }

    if (x >< 42)
    {
        println(0)
    }
    else
    {
        println(2)
    }

    var bool flag = true
    if (flag == true)
    {
        println(3)
    }

    flag = false
    if (flag == false)
    {
        println(4)
    }
}

void <- testIfInLoop()
{
    var int evens = 0
    var int odds = 0

    repeat (i in 0 .. 10)
    {
        if (i % 2 == 0)
        {
            evens = evens + 1
        }
        else
        {
            odds = odds + 1
        }
    }

    println(evens)
    println(odds)
}

void <- testIfBreakContinue()
{
    var int sum = 0
    repeat (i in 0 .. 10)
    {
        if (i == 5)
        {
            break
        }

        sum = sum + i
    }

    println(sum)

    var int count = 0
    repeat (i in 0 .. 10)
    {
        if (i % 2 == 0)
        {
            continue
        }
        count = count + 1
    }

    println(count)
}

int <- sign(int x)
{
    if (x > 0)
    {
        return 1
    }
    else if (x < 0)
    {
        return -1
    }
    return 0
}

int <- max2(int a, int b)
{
    if (a >= b)
    {
        return a
    }
    return b
}

int <- clamp(int x, int lo, int hi)
{
    if (x < lo)
    {
        return lo
    }
    if (x > hi)
    {
        return hi
    }
    return x
}

void <- testReturnInIf()
{
    println(sign(10))
    println(sign(-5))
    println(sign(0))

    println(max2(3, 7))
    println(max2(9, 4))
    println(max2(5, 5))

    println(clamp(3, 0, 10))
    println(clamp(-5, 0, 10))
    println(clamp(15, 0, 10))
}

void <- testExprCondition()
{
    var int x = 4
    if (x * x > 10)
    {
        println(1)
    }

    val array[int] arr = [1, 2, 3, 4, 5]
    if (arr.size > 3)
    {
        println(2)
    }

    if (arr[2] == 3)
    {
        println(3)
    }

    var int a = 2
    var int b = 3
    if (a + b == 5 and a * b == 6)
    {
        println(4)
    }
}

void <- testIfFallthrough()
{
    var int x = 10
    if (x > 100)
    {
        x = 100
    }
    println(x)
    if (x > 5)
    {
        x = x * 2
    }
    println(x)

    if (x > 100)
    {
        x = 0
    }
    println(x)
}

void <- testRealConditions()
{
    var real r = 3.14
    if (r > 3.0)
    {
        println(1)
    }

    if (r < 3.0)
    {
        println(0)
    }
    else
    {
        println(2)
    }

    var real zero = 0.0
    if (zero == 0.0)
    {
        println(3)
    }
}

int <- fizzbuzz(int n)
{
    if (n % 15 == 0)
    {
        return 0
    }
    else if (n % 3 == 0)
    {
        return 3
    }
    else if (n % 5 == 0)
    {
        return 5
    }
    else
    {
        return n
    }
}

void <- testFizzBuzz()
{
    println(fizzbuzz(15))
    println(fizzbuzz(9))
    println(fizzbuzz(10))
    println(fizzbuzz(7))
}

void <- main()
{
    testIfOnly()
    testIfElse()
    testChain()
    testLongChainCases()
    testNested()
    testLogicalOps()
    testEquality()
    testIfInLoop()
    testIfBreakContinue()
    testReturnInIf()
    testExprCondition()
    testIfFallthrough()
    testRealConditions()
    testFizzBuzz()
}

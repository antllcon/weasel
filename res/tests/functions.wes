int <- binarySearch(val array[int] arr, int target)
{
    var uint lo = 0
    var uint hi = arr.size

    run (lo < hi)
    {
        val uint mid = lo + (hi - lo) / 2
        when
        {
            arr[mid] == target -> return mid.int()
            arr[mid] < target -> lo = mid + 1
            else -> hi = mid
        }
    }
    return -1
}

void <- bubbleSort(var array[int] arr)
{
    val int n = arr.size.int()
    repeat (i in 0 .. n)
    {
        repeat (j in 0 .. n - i - 1)
        {
            when
            {
                arr[j.uint()] > arr[j.uint() + 1] -> {
                    val int tmp = arr[j.uint()]
                    arr[j.uint()] = arr[j.uint() + 1]
                    arr[j.uint() + 1] = tmp
                }
            }
        }
    }
}

void <- movingAverage(val array[real] src, var array[real] dst, int window)
{
    repeat (i in 0 .. src.size)
    {
        var real acc = 0.0
        var int count = 0
        var int k = i.int() - window + 1
        run (k <= i.int())
        {
            when
            {
                k >= 0 -> {
                    acc = acc + src[k.uint()]
                    count = count + 1
                }
            }
            k = k + 1
        }
        dst[i] = acc / count.real()
    }
}

int <- sumArray(val array[int] arr)
{
    var int total = 0
    repeat (v in arr)
    {
        total = total + v
    }
    return total
}

void <- testArrayUtils()
{
    var array[int] nums = [1, 3, 5, 7, 9, 11, 13]
    println(binarySearch(nums, 7))
    println(binarySearch(nums, 4))

    var array[int] unsorted = [64, 34, 25, 12, 22, 11, 90]
    bubbleSort(unsorted)
    println(unsorted[0])   # 11
    println(unsorted[6])   # 90
}

real <- abs(real x)
{
    when
    {
        x < 0.0 -> return x * -1.0
        else -> return x
    }
}

real <- power(real base, var int exp)
{
    var real result = 1.0
    run (exp > 0)
    {
        result = result * base
        exp = exp - 1
    }
    return result
}

int <- gcd(var int a, var int b)
{
    run (b >< 0)
    {
        val int tmp = b
        b = a % b
        a = tmp
    }
    return a
}

int <- lcm(int a, int b)
{
    return a / gcd(a, b) * b
}

void <- testMath()
{
    println(abs(-3.14))
    println(abs(2.71))
    println(power(2.0, 10))
    println(power(3.0, 3))
    println(gcd(48, 18))
    println(lcm(4, 6))
}

int <- partition(var array[int] arr, int lo, int hi)
{
    val int pivot = arr[hi.uint()]
    var int i = lo - 1
    repeat (j in lo .. hi)
    {
        when
        {
            arr[j.uint()] <= pivot -> {
                i = i + 1
                val int tmp = arr[i.uint()]
                arr[i.uint()] = arr[j.uint()]
                arr[j.uint()] = tmp
            }
        }
    }
    val int tmp = arr[i.uint() + 1]
    arr[i.uint() + 1] = arr[hi.uint()]
    arr[hi.uint()] = tmp
    return i + 1
}

void <- quickSort(var array[int] arr, int lo, int hi)
{
    when
    {
        lo < hi -> {
            val int pi = partition(arr, lo, hi)
            quickSort(arr, lo, pi - 1)
            quickSort(arr, pi + 1, hi)
        }
    }
}

void <- testQuickSort()
{
    var array[int] data = [38, 27, 43, 3, 9, 82, 10]
    quickSort(data, 0, data.size.int() - 1)
    repeat (i in 0 .. data.size)
    {
        print(data[i], " ")
    }
    println("")
    # ожидается: 3 9 10 27 38 43 82
}

int <- countInRange(val array[int] arr, int lo, int hi)
{
    var int count = 0
    repeat (i in 0 .. arr.size)
    {
        when
        {
            arr[i] >= lo and arr[i] <= hi -> count = count + 1
        }
    }
    return count
}

void <- buildHistogram(val array[int] data, var array[int] buckets, int bucketSize)
{
    repeat (i in 0 .. data.size)
    {
        val int bucket = data[i] / bucketSize
        when
        {
            bucket >= 0 and bucket < buckets.size.int() -> buckets[bucket.uint()] = buckets[bucket.uint()] + 1
        }
    }
}

void <- testHighOrder()
{
    val array[int] values = [2, 7, 1, 8, 2, 8, 1, 8, 2, 8, 4]
    println(countInRange(values, 1, 3))
    println(countInRange(values, 7, 9))

    var array[int] hist = array[int](10)
    buildHistogram(values, hist, 3)
    println(hist[0])
    println(hist[2])
}

array[int] <- filter(val array[int] src, int threshold)
{
    var int count = 0
    repeat (i in 0 .. src.size)
    {
        when
        {
            src[i] >= threshold -> count = count + 1
        }
    }
    var array[int] result = array[int](count.uint())
    var int idx = 0
    repeat (i in 0 .. src.size)
    {
        when
        {
            src[i] >= threshold -> {
                result[idx.uint()] = src[i]
                idx = idx + 1
            }
        }
    }
    return result
}

array[int] <- mapSquare(val array[int] src)
{
    var array[int] result = array[int](src.size)
    repeat (i in 0 .. src.size)
    {
        result[i] = src[i] * src[i]
    }
    return result
}

void <- testChaining()
{
    val array[int] raw = [1, 3, 5, 2, 8, 4, 7, 6]

    val array[int] big = filter(raw, 5)
    println(big.size)

    val array[int] squared = mapSquare(big)
    println(squared[0])
    println(squared[1])

    println(sumArray(squared))
}

void <- main()
{
    testArrayUtils()
    testMath()
    testQuickSort()
    testHighOrder()
    testChaining()
}

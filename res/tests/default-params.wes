# ============================================================
# Значения параметров по умолчанию
# ============================================================
# Позитивные кейсы должны компилироваться и выполняться.
# Негативные — внизу, закомментированы.
# ============================================================

# Один дефолтный параметр в хвосте
int <- inc(int x, int by = 1)
{
    return x + by
}

# Все параметры с дефолтами — можно звать без аргументов
int <- box(int w = 10, int h = 20)
{
    return w * h
}

# Обязательный + дефолтный (строка)
string <- greet(string name, string greeting = "Привет")
{
    return greeting
}

# Дефолт-выражение (литералы + арифметика)
int <- offset(int base, int delta = 3 + 4)
{
    return base + delta
}

# real-дефолт
real <- scale(real x, real factor = 2.0)
{
    return x * factor
}

void <- main()
{
    println(inc(5))           # 6   -> step=1
    println(inc(5, 3))        # 8   -> step=3

    println(box())            # 200 -> 10*20
    println(box(5))           # 100 -> 5*20
    println(box(5, 5))        # 25  -> 5*5

    println(greet("Боб"))         # Привет
    println(greet("Боб", "Хай"))  # Хай

    println(offset(10))       # 17  -> delta=7
    println(offset(10, 100))  # 110

    println(scale(4.0))       # 8.0  -> factor=2.0
    println(scale(4.0, 0.5))  # 2.0
}

# ============================================================
# НЕГАТИВНЫЕ КЕЙСЫ — раскомментируй по одному.
# ============================================================


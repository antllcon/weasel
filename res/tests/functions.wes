# ============================================================
# Полезные функции — реальные алгоритмы с разными видами передачи
# ============================================================

struct Matrix
[
    var array[real] data
    var uint rows
    var uint cols
]

struct Stats
[
    var real min
    var real max
    var real sum
    var uint count
]

# ============================================================
# УТИЛИТЫ ДЛЯ МАССИВОВ
# ============================================================

# Бинарный поиск — val: только читает
int <- binarySearch(val array[int] arr, int target)
{
    var uint lo = 0
    var uint hi = arr.size
    run (lo < hi)
    {
        val uint mid = lo + (hi - lo) / 2
        when
        {
            arr[mid] == target -> return mid.int()
            arr[mid] < target -> lo = mid + 1
            else -> hi = mid
        }
    }
    return -1
}

# Пузырьковая сортировка — var: изменяет массив
void <- bubbleSort(var array[int] arr)
{
    val uint n = arr.size
    repeat (int i = 0; i < n.int(); i = i + 1)
    {
        repeat (int j = 0; j < n.int() - i - 1; j = j + 1)
        {
            when
            {
                arr[j] > arr[j + 1] ->
                {
                    val int tmp = arr[j]
                    arr[j] = arr[j + 1]
                    arr[j + 1] = tmp
                }
            }
        }
    }
}

# Подсчёт статистики — val: только читает
Stats <- computeStats(val array[real] data)
{
    var Stats s = Stats
    {
        min   = data[0]
        max   = data[0]
        sum   = 0.0
        count = data.size
    }
    repeat (i in 0 .. data.size)
    {
        when { data[i] < s.min -> s.min = data[i] }
        when { data[i] > s.max -> s.max = data[i] }
        s.sum = s.sum + data[i]
    }
    return s
}

# Скользящее среднее — val читает src, var пишет в dst
void <- movingAverage(val array[real] src, var array[real] dst, int window)
{
    val uint n = src.size
    repeat (i in 0 .. n)
    {
        var real acc = 0.0
        var int count = 0
        repeat (int k = i.int() - window + 1; k <= i.int(); k = k + 1)
        {
            when
            {
                k >= 0 ->
                {
                    acc = acc + src[k.uint()]
                    count = count + 1
                }
            }
        }
        dst[i] = acc / count.real()
    }
}

void <- testArrayUtils()
{
    var array[int] nums = [1, 3, 5, 7, 9, 11, 13]
    println(binarySearch(nums, 7))    # 3
    println(binarySearch(nums, 4))    # -1

    var array[int] unsorted = [64, 34, 25, 12, 22, 11, 90]
    bubbleSort(unsorted)
    println(unsorted[0])   # 11
    println(unsorted[6])   # 90

    var array[real] prices = [1.5, 3.2, 2.8, 4.1, 3.9]
    val Stats s = computeStats(prices)
    println(s.min)         # 1.5
    println(s.max)         # 4.1
    println(s.count)       # 5
}

# ============================================================
# СТРОКИ И ЧИСЛА
# ============================================================

# Возвращает абсолютное значение — скаляр всегда по значению
real <- abs(real x)
{
    when
    {
        x < 0.0 -> return x * -1.0
        else    -> return x
    }
}

# Возведение в степень — скаляры по значению
real <- power(real base, var int exp)
{
    var real result = 1.0
    run (exp > 0)
    {
        result = result * base
        exp = exp - 1
    }
    return result
}

# GCD — скаляры всегда копируются
int <- gcd(var int a, var int b)
{
    run (b >< 0)
    {
        val int tmp = b
        b = a % b
        a = tmp
    }
    return a
}

int <- lcm(int a, int b)
{
    return a / gcd(a, b) * b
}

void <- testMath()
{
    println(abs(-3.14))         # 3.14
    println(abs(2.71))          # 2.71
    println(power(2.0, 10))     # 1024.0
    println(power(3.0, 3))      # 27.0
    println(gcd(48, 18))        # 6
    println(lcm(4, 6))          # 12
}

# ============================================================
# АЛГОРИТМЫ С НЕСКОЛЬКИМИ ТИПАМИ ПАРАМЕТРОВ
# ============================================================

# Partition для QuickSort
# val bounds: только читает массив для сравнения (не меняет)
# var arr: переставляет элементы
int <- partition(var array[int] arr, int lo, int hi)
{
    val int pivot = arr[hi]
    var int i = lo - 1
    repeat (int j = lo; j < hi; j = j + 1)
    {
        when
        {
            arr[j] <= pivot ->
            {
                i = i + 1
                val int tmp = arr[i]
                arr[i] = arr[j]
                arr[j] = tmp
            }
        }
    }
    val int tmp = arr[i + 1]
    arr[i + 1] = arr[hi]
    arr[hi] = tmp
    return i + 1
}

void <- quickSort(var array[int] arr, int lo, int hi)
{
    when
    {
        lo < hi ->
        {
            val int pi = partition(arr, lo, hi)
            quickSort(arr, lo, pi - 1)
            quickSort(arr, pi + 1, hi)
        }
    }
}

void <- testQuickSort()
{
    var array[int] data = [38, 27, 43, 3, 9, 82, 10]
    quickSort(data, 0, data.size.int() - 1)
    repeat (i in 0 .. data.size)
    {
        print(data[i], " ")
    }
    println("")
    # ожидается: 3 9 10 27 38 43 82
}

# ============================================================
# ФУНКЦИИ ВЫСШЕГО ПОРЯДКА — структуры как val и без модификатора
# ============================================================

# Применить смещение к точке — без модификатора: копия Point
# (в будущем: Point без modifier = by value, вызывающая не видит изменений)

# Считает, сколько элементов в диапазоне — val массив, скаляры по значению
int <- countInRange(val array[int] arr, int lo, int hi)
{
    var int count = 0
    repeat (i in 0 .. arr.size)
    {
        when
        {
            arr[i] >= lo and arr[i] <= hi -> count = count + 1
        }
    }
    return count
}

# Histogram: var для записи в buckets, val для чтения data
void <- buildHistogram(val array[int] data, var array[int] buckets, int bucketSize)
{
    repeat (i in 0 .. data.size)
    {
        val int bucket = data[i] / bucketSize
        when
        {
            bucket >= 0 and bucket < buckets.size.int() ->
                buckets[bucket] = buckets[bucket] + 1
        }
    }
}

void <- testHighOrder()
{
    val array[int] values = [2, 7, 1, 8, 2, 8, 1, 8, 2, 8, 4]
    println(countInRange(values, 1, 3))    # 5 (1,2,2,1,2)
    println(countInRange(values, 7, 9))    # 5 (7,8,8,8,8)

    var array[int] hist = array[int](10)
    buildHistogram(values, hist, 3)
    # bucket 0 (0-2): числа 2,1,2,1,2 = 5
    # bucket 2 (6-8): числа 7,8,8,8,8 = 5
    println(hist[0])   # 5
    println(hist[2])   # 5
}

# ============================================================
# ЦЕПОЧКИ ФУНКЦИЙ — результаты одних передаются в другие
# ============================================================

array[int] <- filter(val array[int] src, int threshold)
{
    var int count = 0
    repeat (i in 0 .. src.size)
    {
        when { src[i] >= threshold -> count = count + 1 }
    }
    var array[int] result = array[int](count.uint())
    var int idx = 0
    repeat (i in 0 .. src.size)
    {
        when
        {
            src[i] >= threshold ->
            {
                result[idx] = src[i]
                idx = idx + 1
            }
        }
    }
    return result
}

array[int] <- mapSquare(val array[int] src)
{
    var array[int] result = array[int](src.size)
    repeat (i in 0 .. src.size)
    {
        result[i] = src[i] * src[i]
    }
    return result
}

void <- testChaining()
{
    val array[int] raw = [1, 3, 5, 2, 8, 4, 7, 6]

    # filter → только >= 5
    val array[int] big = filter(raw, 5)
    println(big.size)      # 4 (5, 8, 7, 6)

    # mapSquare → квадраты
    val array[int] squared = mapSquare(big)
    println(squared[0])    # 25 (5*5)
    println(squared[1])    # 64 (8*8)

    # sum итогового
    println(sumArray(squared))   # 25 + 64 + 49 + 36 = 174
}

# ============================================================
# MAIN
# ============================================================

void <- main()
{
    testArrayUtils()
    testMath()
    testQuickSort()
    testHighOrder()
    testChaining()
}

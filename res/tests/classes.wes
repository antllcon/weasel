# ============================================================
# Классы — Фазы 1–5: поля, конструкторы, методы, this,
# ссылочная семантика, видимость public/private
# ============================================================

# Пользовательский конструктор + доступ к полям (поля публичные)
class Point
{
    public {
        var real x
        var real y
    }

    Point(real px, real py)
    {
        x = px
        y = py
    }
}

# Перегрузка конструкторов
class Box
{
    public {
        var int w
        var int h
    }

    Box(int side)
    {
        w = side
        h = side
    }

    Box(int width, int height)
    {
        w = width
        h = height
    }
}

class Counter
{
    public {
        var int value = 0
        var int steper = 5
    }
}

class Rect
{
    var int w
    var int h

    Rect(int rw, int rh)
    {
        this.w = rw
        this.h = rh
    }

    public {
        int <- area()
        {
            return w * h
        }

        int <- scaled(int factor)
        {
            return area() * factor
        }

        void <- grow(int dw, int dh)
        {
            w = w + dw
            h = h + dh
        }
    }
}

void <- mutate(Point p)
{
    p.x = 99.0
}

class Account
{
    var int balance

    Account(int initial)
    {
        balance = initial
    }

    int <- bonus()
    {
        return balance / 10
    }

    public {
        void <- deposit(int amount)
        {
            balance = balance + amount
        }

        int <- total()
        {
            return balance + bonus()
        }
    }
}

class Line
{
    public {
        var Point a
        var Point b

        Line(Point pa, Point pb)
        {
            a = pa
            b = pb
        }

        real <- spanX()
        {
            return b.x - a.x
        }
    }
}

void <- main()
{
    var Point p = Point(3.0, 4.0)
    println(p.x)
    println(p.y)

    var Point q = p
    q.x = 9.0
    println(p.x)

    var Box sq = Box(5)
    println(sq.w)
    println(sq.h)
    var Box rect = Box(3, 4)
    println(rect.w)
    println(rect.h)

    var Counter c = Counter()
    println(c.value)
    println(c.steper)

    var Rect r = Rect(3, 4)
    println(r.area())
    println(r.scaled(2))
    r.grow(1, 1)
    println(r.area())

    mutate(p)
    println(p.x)

    println(p == q)
    var Point fresh = Point(99.0, 4.0)
    println(p == fresh)
    println(p >< fresh)

    var Account acc = Account(100)
    acc.deposit(50)
    println(acc.total())
    # println(acc.balance) # приватный метод
    # println(acc.bonus()) # приватный метод

    # Фаза 7: композиция — объект как поле
    var Point start = Point(0.0, 0.0)
    var Point finish = Point(3.0, 0.0)
    var Line seg = Line(start, finish)
    println(seg.a.x)
    println(seg.b.x)
    println(seg.spanX())
    seg.a.x = 1.0
    println(seg.a.x)
    println(start.x)

    var array[Point] pts = array[Point](2)
    pts[0] = Point(5.0, 6.0)
    pts[1] = Point(7.0, 8.0)
    println(pts[0].x)
    println(pts[1].y)
    pts[0].x = 50.0
    println(pts[0].x)
}

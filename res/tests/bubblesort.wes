void <- sort()
{
        var array[int] data = [3, 6, 10, 22, 67, 10, 1, 3]
        val uint arraySize = data.size

        repeat (i in 0 .. arraySize)
        {
            repeat (j in 0 .. arraySize - i - 1.uint())
            {
                when
                {
                    data[j] > data[j + 1] -> {
                        val int temp = data[j]
                        data[j] = data[j + 1]
                        data[j + 1] = temp
                    }
                }
            }
        }

    println("Sorted array:")

    repeat (k in 0 .. arraySize)
    {
        print(data[k], "")
    }
}

void <- main()
{
    sort()
}
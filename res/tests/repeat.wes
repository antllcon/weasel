void <- testRangeBasicInt()
{
    repeat (i in 0 .. 5)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeWithUint()
{
    val uint limit = 6
    repeat (i in 0 .. limit)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeWithExpression()
{
    val int base = 2
    val int count = 4
    repeat (i in base .. base + count)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeNested()
{
    repeat (i in 0 .. 3)
    {
        repeat (j in 0 .. 3)
        {
            print(i * 3 + j, " ")
        }
        println("")
    }
}

void <- testClassicBasic()
{
    repeat (int i = 0; i < 5; i = i + 1)
    {
        print(i, " ")
    }
    println("")
}

void <- testClassicCountDown()
{
    repeat (int i = 10; i > 0; i = i - 2)
    {
        print(i, " ")
    }
    println("")
}

void <- testClassicSumArray()
{
    val array[int] values = [3, 7, 2, 9, 1]
    var int sum = 0
    repeat (int i = 0; i < 5; i = i + 1)
    {
        sum = sum + values[i]
    }
    println(sum)
}

void <- testClassicFibonacci()
{
    var int a = 0
    var int b = 1
    repeat (int step = 0; step < 8; step = step + 1)
    {
        print(a, " ")
        val int next = a + b
        a = b
        b = next
    }
    println("")
}

void <- testClassicNestedLoops()
{
    repeat (int i = 1; i <= 3; i = i + 1)
    {
        repeat (int j = 1; j <= 3; j = j + 1)
        {
            print(i * j, " ")
        }
        println("")
    }
}

void <- main()
{
    testRangeBasicInt()
    testRangeWithUint()
    testRangeWithExpression()
    testRangeNested()
    testClassicBasic()
    testClassicCountDown()
    testClassicSumArray()
    testClassicFibonacci()
    testClassicNestedLoops()
}

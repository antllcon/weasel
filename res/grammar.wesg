MulExpr -> MulExpr % UnaryExpr
MulExpr -> UnaryExpr

UnaryExpr -> not UnaryExpr
UnaryExpr -> & UnaryExpr
UnaryExpr -> * UnaryExpr
UnaryExpr -> - UnaryExpr
UnaryExpr -> PostfixExpr

PostfixExpr -> PostfixExpr . MethodName ( ArgList )
PostfixExpr -> PostfixExpr . MethodName ( )
PostfixExpr -> PostfixExpr . MethodName
PostfixExpr -> PostfixExpr [ Expr ]
PostfixExpr -> PrimaryExpr

MethodName -> id
MethodName -> int
MethodName -> uint
MethodName -> real
MethodName -> bool
MethodName -> string
MethodName -> void

PrimaryExpr -> id
PrimaryExpr -> num
PrimaryExpr -> str
PrimaryExpr -> true
PrimaryExpr -> false

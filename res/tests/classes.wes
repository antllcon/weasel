# ============================================================
# Классы — Фазы 1–5: поля, конструкторы, методы, this,
# ссылочная семантика, видимость public/private
# ============================================================

# Пользовательский конструктор + доступ к полям (поля публичные)
class Point
{
    public {
        var real x
        var real y
    }

    Point(real px, real py)
    {
        x = px
        y = py
    }
}

# Перегрузка конструкторов
class Box
{
    public {
        var int w
        var int h
    }

    Box(int side)
    {
        w = side
        h = side
    }

    Box(int width, int height)
    {
        w = width
        h = height
    }
}

# Нет конструктора → авто-default + инициализаторы полей
class Counter
{
    public {
        var int value = 0
        var int steper = 5
    }
}

# Инкапсуляция: поля private, наружу — только методы (public)
class Rect
{
    var int w
    var int h

    Rect(int rw, int rh)
    {
        this.w = rw
        this.h = rh
    }

    public {
        int <- area()
        {
            return w * h
        }

        int <- scaled(int factor)
        {
            return area() * factor
        }

        void <- grow(int dw, int dh)
        {
            w = w + dw
            h = h + dh
        }
    }
}

# Фаза 4: объект передаётся по ссылке (без копии)
void <- mutate(Point p)
{
    p.x = 99.0
}

# Фаза 5: видимость. Поле private, приватный метод доступен только изнутри.
# Конструкторы вызываемы всегда.
class Account
{
    var int balance

    Account(int initial)
    {
        balance = initial
    }

    # private по умолчанию — доступен только изнутри класса
    int <- bonus()
    {
        return balance / 10
    }

    public {
        void <- deposit(int amount)
        {
            balance = balance + amount
        }

        int <- total()
        {
            return balance + bonus()
        }
    }
}

# Фаза 7: композиция — объект как поле другого объекта
class Line
{
    public {
        var Point a
        var Point b

        Line(Point pa, Point pb)
        {
            a = pa
            b = pb
        }

        # доступ к полям полей-объектов изнутри метода
        real <- spanX()
        {
            return b.x - a.x
        }
    }
}

void <- main()
{
    var Point p = Point(3.0, 4.0)
    println(p.x)         # 3.0
    println(p.y)         # 4.0

    # ссылочная семантика
    var Point q = p
    q.x = 9.0
    println(p.x)         # 9.0

    # перегрузка конструкторов
    var Box sq = Box(5)
    println(sq.w)        # 5
    println(sq.h)        # 5
    var Box rect = Box(3, 4)
    println(rect.w)      # 3
    println(rect.h)      # 4

    # авто-default-конструктор + инициализаторы полей
    var Counter c = Counter()
    println(c.value)     # 0
    println(c.steper)    # 5

    # методы: доступ к полям, this, перегрузка, мутация состояния
    var Rect r = Rect(3, 4)
    println(r.area())    # 12
    println(r.scaled(2)) # 24
    r.grow(1, 1)
    println(r.area())    # 20

    # Фаза 4: передача в функцию — ссылка, не копия
    mutate(p)
    println(p.x)         # 99.0

    # Фаза 4: равенство по ссылке
    println(p == q)      # true  (q — алиас p)
    var Point fresh = Point(99.0, 4.0)
    println(p == fresh)  # false (разные объекты)
    println(p >< fresh)  # true

    # Фаза 5: видимость
    var Account acc = Account(100)
    acc.deposit(50)
    println(acc.total())     # 165 (balance 150 + bonus 15)
    # println(acc.balance)   # ОШИБКА: приватное поле извне
    # println(acc.bonus())   # ОШИБКА: приватный метод извне

    # Фаза 7: композиция — объект как поле
    var Point start = Point(0.0, 0.0)
    var Point finish = Point(3.0, 0.0)
    var Line seg = Line(start, finish)
    println(seg.a.x)         # 0.0
    println(seg.b.x)         # 3.0
    println(seg.spanX())     # 3.0
    seg.a.x = 1.0
    println(seg.a.x)         # 1.0
    println(start.x)         # 1.0 (ссылка: seg.a — это start)

    # Фаза 7: массив объектов
    var array[Point] pts = array[Point](2)
    pts[0] = Point(5.0, 6.0)
    pts[1] = Point(7.0, 8.0)
    println(pts[0].x)        # 5.0
    println(pts[1].y)        # 8.0
    pts[0].x = 50.0
    println(pts[0].x)        # 50.0
}

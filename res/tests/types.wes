void <- main()
{
    val int a := -120
    val uint b := 250
    val int c := -30000
    val uint d := 4294967295
    val int e := -9000000000000000000
    val real f := 3.14
    val real g := 2.7182818284
    val bool h := true
    val string i := "Weasel Language"

    print("Печать базовых типов данных")
    print("int a:", a)
    print("uint b:", b)
    print("int c:", c)
    print("uint d:", d)
    print("int e:", e)
    print("real f:", f)
    print("real g:", g)
    print("bool h:", h)
    print("string i:", i)
    print()

    print("Явное приведение типов")
    print("1. real(2.718) -> int :", g.int())
    print("2. real(3.14) -> uint:", f.uint())
    print("3. uint(250) -> real:", b.real())
    print("4. uint(429..) -> int :", d.int())
    print("5. int(-30000) -> real:", c.real())
    print("6. int(-120) -> uint:", a.uint())
}


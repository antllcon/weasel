Program -> DeclList

DeclList -> DeclList Decl
DeclList -> e

Decl -> FuncDecl
Decl -> StructDecl
Decl -> EnumDecl
Decl -> UnionDecl
Decl -> VarDecl
Decl -> ClassDecl

ClassDecl -> class id { ClassBody }

ClassBody -> ClassBody ClassMember
ClassBody -> e

ClassMember -> VarDecl nl
ClassMember -> FuncDecl

Type -> BaseType
Type -> id
Type -> array [ Type ]

BaseType -> int
BaseType -> uint
BaseType -> real
BaseType -> bool
BaseType -> string
BaseType -> void

FuncDecl -> Type <- id ( ParamList ) { StmtList }
FuncDecl -> Type <- id ( ) { StmtList }

ParamList -> ParamList , Param
ParamList -> Param

Param -> Modifier Type id
Param -> Type id

StructDecl -> struct id [ FieldList ]
UnionDecl -> union id [ FieldList ]

FieldList -> FieldList Field
FieldList -> e
Field -> Type id

EnumDecl -> enum id [ EnumIdList ]
EnumIdList -> EnumIdList , id
EnumIdList -> id

StmtList -> StmtList Stmt
StmtList -> e

Stmt -> VarDecl nl
Stmt -> AssignStmt nl
Stmt -> ReturnStmt nl
Stmt -> ExprStmt nl
Stmt -> WhileStmt
Stmt -> DoWhileStmt
Stmt -> ForStmt
Stmt -> IfStmt
Stmt -> WhenStmt
Stmt -> BreakStmt nl
Stmt -> ContinueStmt nl
Stmt -> { StmtList } nl

IfStmt -> if ( Expr ) { StmtList } ElseOpt

ElseOpt -> else { StmtList }
ElseOpt -> else IfStmt
ElseOpt -> e

WhenStmt -> when { WhenEntries WhenElseOpt }
WhenStmt -> when ( Expr ) { WhenEntries WhenElseOpt }

WhenEntries -> WhenEntries WhenEntry
WhenEntries -> e

WhenEntry -> WhenConditions -> Stmt

WhenConditions -> WhenConditions , Expr
WhenConditions -> Expr

WhenElseOpt -> else -> Stmt
WhenElseOpt -> e

VarDecl -> Modifier Type id AssignOp Expr
VarDecl -> Modifier Type id

Modifier -> val
Modifier -> var
Modifier -> let

AssignOp -> =
AssignOp -> <-

AssignStmt -> Expr AssignOp Expr

WhileStmt -> run ( Expr ) { StmtList }
DoWhileStmt -> { StmtList } run ( Expr )

ForStmt -> repeat ( id in Expr .. Expr ) { StmtList }
ForStmt -> repeat ( id , id in Expr .. Expr , Expr .. Expr ) { StmtList }
ForStmt -> repeat ( BaseType id = Expr ; Expr ; AssignStmt ) { StmtList }

BreakStmt -> break
ContinueStmt -> continue

ReturnStmt -> return Expr
ReturnStmt -> return

ExprStmt -> Expr

Expr -> LogicOrExpr

LogicOrExpr -> LogicOrExpr or LogicAndExpr
LogicOrExpr -> LogicAndExpr

LogicAndExpr -> LogicAndExpr and EqExpr
LogicAndExpr -> EqExpr

EqExpr -> EqExpr == RelExpr
EqExpr -> EqExpr >< RelExpr
EqExpr -> RelExpr

RelExpr -> RelExpr < AddExpr
RelExpr -> RelExpr > AddExpr
RelExpr -> RelExpr <= AddExpr
RelExpr -> RelExpr >= AddExpr
RelExpr -> AddExpr

AddExpr -> AddExpr + MulExpr
AddExpr -> AddExpr - MulExpr
AddExpr -> MulExpr

MulExpr -> MulExpr * UnaryExpr

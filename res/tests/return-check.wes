# {
#     when
#     {
#         x > 0  -> return 1
#         x <= 0 -> return 0
#     }
# }

# --- E. Возврат только внутри цикла (тело может не выполниться) ---
# int <- n5(int n)
# {
#     repeat (i in 0 .. n)
#     {
#         return i
#     }
# }


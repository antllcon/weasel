# ============================================================
# Проверка анализа возврата (DefinitelyReturns)
# ============================================================
# Все функции НИЖЕ обязаны КОМПИЛИРОВАТЬСЯ и выполняться —
# это позитивные кейсы (никаких ложных срабатываний).
# Негативные кейсы — внизу, закомментированы. Раскомментируй
# по одному, чтобы увидеть ошибку:
#   "Функция '...' должна возвращать значение на всех путях выполнения"
# ============================================================

# 1. Тривиальный хвостовой возврат
int <- p1(int x)
{
    return x
}

# 2. if/else — обе ветви возвращают, без хвостового return
int <- p2(int x)
{
    if (x > 0)
    {
        return 1
    }
    else
    {
        return 0
    }
}

# 3. Цепочка if / else if / else — все ветви возвращают
int <- p3(int x)
{
    if (x > 10)
    {
        return 3
    }
    else if (x > 5)
    {
        return 2
    }
    else
    {
        return 1
    }
}

# 4. Ранний возврат в if + хвостовой возврат
int <- p4(int x)
{
    if (x < 0)
    {
        return 0
    }
    return x * 2
}

# 5. Вложенные if/else — все пути возвращают
int <- p5(int x, int y)
{
    if (x > 0)
    {
        if (y > 0)
        {
            return 1
        }
        else
        {
            return 2
        }
    }
    else
    {
        return 3
    }
}

# 6. when с else — все ветви возвращают
int <- p6(int x)
{
    when
    {
        x > 0 -> return 1
        x < 0 -> return -1
        else  -> return 0
    }
}

# 7. when с else, ветвь-блок заканчивается возвратом
int <- p7(int x)
{
    when
    {
        x > 0 -> {
            val int t = x * 2
            return t
        }
        else -> return 0
    }
}

# 8. Ранний возврат внутри цикла + хвостовой возврат (гарант — хвост)
int <- p8(int n)
{
    repeat (i in 0 .. n)
    {
        when
        {
            i == 3 -> return i
        }
    }
    return -1
}

# 9. Глубокая смесь if + when — все пути возвращают
int <- p9(int x)
{
    if (x > 100)
    {
        when
        {
            x > 200 -> return 2
            else -> return 1
        }
    }
    else
    {
        return 0
    }
}

# 10. Не-возвращающие операторы перед финальным return
int <- p10(int x)
{
    var int acc = 0
    repeat (i in 0 .. x)
    {
        acc = acc + i
    }
    if (acc > 100)
    {
        return 100
    }
    return acc
}

# 11. else-ветвь — блок с вложенным if/else (оба возвращают)
int <- p11(int x)
{
    if (x == 0)
    {
        return 0
    }
    else
    {
        if (x > 0)
        {
            return 1
        }
        else
        {
            return -1
        }
    }
}

# 12. real-функция: when с else, обе ветви возвращают
real <- p12(real x)
{
    when
    {
        x < 0.0 -> return x * -1.0
        else -> return x
    }
}

# 13. Рекурсия с гарантированным возвратом на всех путях
int <- p13(int n)
{
    if (n <= 1)
    {
        return 1
    }
    return n * p13(n - 1)
}

void <- main()
{
    println(p1(42))           # 42
    println(p2(5))            # 1
    println(p2(-5))           # 0
    println(p3(20))           # 3
    println(p3(7))            # 2
    println(p3(1))            # 1
    println(p4(-3))           # 0
    println(p4(4))            # 8
    println(p5(1, 1))         # 1
    println(p5(1, -1))        # 2
    println(p5(-1, 0))        # 3
    println(p6(9))            # 1
    println(p6(-9))           # -1
    println(p6(0))            # 0
    println(p7(3))            # 6
    println(p7(-1))           # 0
    println(p8(10))           # 3
    println(p8(2))            # -1
    println(p9(250))          # 2
    println(p9(150))          # 1
    println(p9(50))           # 0
    println(p10(5))           # 10
    println(p10(20))          # 100
    println(p11(0))           # 0
    println(p11(7))           # 1
    println(p11(-7))          # -1
    println(p12(-2.5))        # 2.5
    println(p12(2.5))         # 2.5
    println(p13(5))           # 120
}

# ============================================================
# НЕГАТИВНЫЕ КЕЙСЫ — раскомментируй ОДИН за раз.
# Каждый обязан дать ошибку семантики о возврате на всех путях.
# ============================================================

# --- A. Нет возврата вообще ---

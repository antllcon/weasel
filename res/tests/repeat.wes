void <- testRangeBasicInt()
{
    repeat (i in 0 .. 5)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeWithUint()
{
    val uint limit = 6
    repeat (i in 0 .. limit)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeWithExpression()
{
    val int base = 2
    val int count = 4
    repeat (i in base .. base + count)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeWithStep()
{
    repeat (i in 0 .. 10 step 2)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeDown()
{
    repeat (i in 5 down 0)
    {
        print(i, " ")
    }
    println("")
}

void <- testRangeNested()
{
    repeat (i in 0 .. 3)
    {
        repeat (j in 0 .. 3)
        {
            print(i * 3 + j, " ")
        }
        println("")
    }
}

void <- testCollection()
{
    val array[int] nums = [3, 7, 2, 9, 1]
    repeat (n in nums)
    {
        print(n, " ")
    }
    println("")
}

void <- testCollectionIndexed()
{
    val array[int] nums = [10, 20, 30]
    repeat (i, n in nums)
    {
        print(i, ":", n, " ")
    }
    println("")
}

void <- testCollectionSum()
{
    val array[int] values = [3, 7, 2, 9, 1]
    var int sum = 0
    repeat (v in values)
    {
        sum = sum + v
    }
    println(sum)
}

void <- testTimesLiteral()
{
    repeat (3 times)
    {
        print("* ")
    }
    println("")
}

void <- testTimesVariable()
{
    val int n = 5
    repeat (n times)
    {
        print("# ")
    }
    println("")
}

void <- main()
{
    testRangeBasicInt()
    testRangeWithUint()
    testRangeWithExpression()
    testRangeWithStep()
    testRangeDown()
    testRangeNested()
    testCollection()
    testCollectionIndexed()
    testCollectionSum()
    testTimesLiteral()
    testTimesVariable()
}